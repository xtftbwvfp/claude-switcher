{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Switcher",
  "version": "0.1.0",
  "identifier": "cn.xiaojian.claude-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Switcher",
        "width": 1120,
        "height": 760,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "opener": {}
  }
}
